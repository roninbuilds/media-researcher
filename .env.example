# media-researcher environment variables
# Copy this file to .env (git-ignored) and fill in your keys.
# Never commit .env to version control.

# ── Primary (xAI / Grok) ─────────────────────────────────────────────────────
XAI_API_KEY=xai-...
XAI_MODEL=grok-3-latest           # optional, default: grok-3-latest

# ── Podcast discovery ─────────────────────────────────────────────────────────
LISTEN_NOTES_API_KEY=             # https://www.listennotes.com/api/

# ── Journalist discovery ──────────────────────────────────────────────────────
MUCK_RACK_API_KEY=                # https://muckrack.com/api  (enterprise)
APOLLO_API_KEY=                   # https://www.apollo.io/  (fallback)

# ── Enrichment fallback (Claude) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...      # only needed if XAI_API_KEY is absent

# ── Outreach (TinyFish) ───────────────────────────────────────────────────────
TINYFISH_API_KEY=sk-tinyfish-...  # https://www.tinyfish.ai/
OUTREACH_SENDER_NAME=
OUTREACH_SENDER_EMAIL=
OUTREACH_SENDER_COMPANY=          # optional
OUTREACH_DELAY_SECONDS=10         # seconds between form submissions (default: 10)
# OUTREACH_BODY_TEMPLATE=         # override default message template

# ── Notion output (optional) ──────────────────────────────────────────────────
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Paths & behaviour ─────────────────────────────────────────────────────────
MEDIA_RESEARCHER_OUTPUT_DIR=/mnt/user-data/outputs
MEDIA_RESEARCHER_CACHE_DIR=~/.cache/media-researcher
MEDIA_RESEARCHER_CACHE_TTL=604800   # 7 days in seconds

# ── Scoring weights (must sum to 1.0) ─────────────────────────────────────────
SCORER_WEIGHT_TOPICAL_FIT=0.35
SCORER_WEIGHT_AUDIENCE=0.25
SCORER_WEIGHT_RECENCY=0.20
SCORER_WEIGHT_RESPONSE_LIKELIHOOD=0.20
